generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["nativeDistinct", "relationJoins"]
  engineType      = "client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["autohaus"]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model Adresse {
  id          Int      @id @default(autoincrement())
  plz         String
  ort         String
  land        String
  autohausId  Int @map("autohaus_id") @unique
  autohaus    Autohaus @relation(fields: [autohausId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([autohausId])
  @@index([plz])
  @@map("adresse")
  @@schema("autohaus")
}

model Auto {
  id          Int      @id @default(autoincrement())
  kennzeichen String
  marke       String
  modell      String
  baujahr     Decimal  @db.Decimal(4, 0)
  autohausId  Int @map("autohaus_id")
  autohaus    Autohaus @relation(fields: [autohausId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([autohausId])
  @@index([kennzeichen])
  @@map("auto")
  @@schema("autohaus")
}

model Autohaus {
  id               Int            @id @default(autoincrement())
  version          Int            @default(0)
  name             String
  username         String
  email            String
  anzahlFahrzeuge  Int @map("anzahl_fahrzeuge")
  gruendungsdatum  DateTime       @db.Date
  homepage         String?
  telefonnummer    String?
  erzeugt          DateTime       @default(now()) @db.Timestamp(6)
  aktualisiert     DateTime       @default(now()) @db.Timestamp(6) @updatedAt
  adresse          Adresse?
  autos            Auto[]
  autohausFile     AutohausFile?

  @@index([name])
  @@map("autohaus")
  @@schema("autohaus")
}

model AutohausFile {
  id          Int      @id @default(autoincrement())
  data        Bytes
  filename    String
  mimetype    String?
  autohausId  Int      @map("autohaus_id") @unique
  autohaus    Autohaus @relation(fields: [autohausId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([autohausId])
  @@map("autohaus_file")
  @@schema("autohaus")
}
