generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["nativeDistinct", "relationJoins"]
  engineType      = "client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["autohaus"]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model adresse {
  id          Int      @id @default(autoincrement())
  plz         String
  ort         String
  land        String
  autohaus_id Int
  autohaus    autohaus @relation(fields: [autohaus_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([autohaus_id])
  @@index([plz])
  @@schema("autohaus")
}

model auto {
  id          Int      @id @default(autoincrement())
  kennzeichen String
  marke       String
  modell      String
  baujahr     Decimal  @db.Decimal(4, 0)
  autohaus_id Int
  autohaus    autohaus @relation(fields: [autohaus_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([autohaus_id])
  @@index([kennzeichen])
  @@schema("autohaus")
}

model autohaus {
  id               Int       @id @default(autoincrement())
  version          Int       @default(0)
  name             String
  username         String
  email            String
  anzahl_fahrzeuge Int
  gruendungsdatum  DateTime  @db.Date
  homepage         String?
  telefonnummer    String?
  erzeugt          DateTime  @default(now()) @db.Timestamp(6)
  aktualisiert     DateTime  @default(now()) @db.Timestamp(6)
  adresse          adresse[]
  auto             auto[]

  @@index([name])
  @@schema("autohaus")
}
